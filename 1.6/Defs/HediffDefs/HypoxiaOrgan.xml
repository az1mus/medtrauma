<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- 低血氧症 - 脑损伤 -->
  <HediffDef>
    <defName>Hypoxia</defName>
    <label>hypoxia</label>
    <description>Low blood oxygen reducing organ efficiency.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(150, 100, 255)</defaultLabelColor>
    <alwaysShowSeverity>true</alwaysShowSeverity>
    <initialSeverity>0.1</initialSeverity>
    <minSeverity>0</minSeverity>
    <maxSeverity>1</maxSeverity>
    <lethalSeverity>1.0</lethalSeverity>
    <stages>
      <li>
        <label>asymptomatic</label>
        <becomeVisible>true</becomeVisible>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.1</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>mild</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.25</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.4</minSeverity>
        <label>moderate</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.4</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.6</minSeverity>
        <label>severe</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.6</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>critical</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.8</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.95</minSeverity>
        <label>anoxic</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.99</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="MedTrauma.HediffCompProperties_HypoxiaOrgan">
        <severityPerDay>1</severityPerDay>
        <recoveryPerDay>1</recoveryPerDay>
      </li>
    </comps>
  </HediffDef>
</Defs>
